<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!---->
	<ThingDef ParentName="BuildingBase">
		<defName>AtmosphericProjector</defName>
		<label>Atmospheric projector</label>
		<description>A special tool for controlling the climate in space, based on the principle of the gravitational field. First of all, the projector creates an area of ​​an artificial atmosphere, spending a large amount of energy, which grows as the coverage area increases. This area is safe for breathing living beings, and also maintains a comfortable temperature.\n\nNext, the projector begins to change the composition of the soil according to a template of known biomes and plants. Organic matter in the form of wood is required for operation.</description>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<drawerType>MapMeshAndRealTime</drawerType>
		<pathCost>0</pathCost>
		<passability>Standable</passability>
		<fillPercent>0.35</fillPercent>
		<graphicData>
			<texPath>Buildings/AtmosphericProjector</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.8</drawSize>
			<shadowData>
				<volume>(0.3, 0.2, 0.3)</volume>
				<offset>(0,0,-0.1)</offset>
			</shadowData>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
		</graphicData>
		<tickerType>Normal</tickerType>
		<rotatable>false</rotatable>
		<selectable>true</selectable>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<repairEffect>ConstructMetal</repairEffect>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>7500</WorkToBuild>
			<Flammability>0.5</Flammability>
			<Beauty>-10</Beauty>
			<Mass>10</Mass>
		</statBases>
		<costList>
			<Gravcore>2</Gravcore>
			<Steel>100</Steel>
			<ComponentSpacer>3</ComponentSpacer>
		</costList>
		<resourcesFractionWhenDeconstructed>0.25</resourcesFractionWhenDeconstructed>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<building>
			<destroySound>BuildingDestroyed_Metal_Small</destroySound>
			<ai_chillDestination>false</ai_chillDestination>
			<isEdifice>false</isEdifice>
		</building>
		<researchPrerequisites>
			<li>AdvancedGravtech</li>
		</researchPrerequisites>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
		<designationCategory>Odyssey</designationCategory>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
		  <li>BuildingsSpecial</li>
		</thingCategories>
		<comps>
			<li Class="ProxyHeat.CompProperties_TemperatureSource">
				<radius>5</radius>
				<tempOutcome>600</tempOutcome>
				<maxTemperature>25</maxTemperature>
				<minTemperature>25</minTemperature>
			</li>
			<li Class="CompProperties_Refuelable">
				<fuelCapacity>75.0</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
					</thingDefs>
				</fuelFilter>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
				<canEjectFuel>true</canEjectFuel>
				<externalTicking>true</externalTicking>
			</li>
			<li Class="CompProperties_Power">
				<compClass>TerraformingAsteroids.CompPowerAtmosphericProjector</compClass>
				<basePowerConsumption>5000</basePowerConsumption>
				<transmitsPower>true</transmitsPower>
			</li>
			<li Class="TerraformingAsteroids.CompProperties_AtmosphericProjector">
				<color>155, 205, 195</color>
				<inactiveColor>0.2, 0.2, 0.2</inactiveColor>
				<idlePulseSpeed>3</idlePulseSpeed>
				<minIdleAlpha>0.05</minIdleAlpha>
				<disarmedByEmpForTicks>600</disarmedByEmpForTicks>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>6</glowRadius>
				<glowColor>155, 205, 195</glowColor>
			</li>
			<li Class="CompProperties_Breakdownable"/>
			<li Class="CompProperties_Flickable"/>
		</comps>
	</ThingDef>
	<!---->
</Defs>