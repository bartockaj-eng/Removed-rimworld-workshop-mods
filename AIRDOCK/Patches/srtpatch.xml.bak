<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>SRTS Expanded</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationReplace">
          <xpath>/Defs/ThingDef[defName="SRTSSuperpod"]/size</xpath>
          <value>
            <size>(3,3)</size>
          </value>
        </li>
        <li Class="PatchOperationReplace">
          <xpath>/Defs/ThingDef[defName="SRTSSkip"]/size</xpath>
          <value>
            <size>(3,3)</size>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
  
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>SRTS Expanded (continued)</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationReplace">
          <xpath>/Defs/ThingDef[defName="SRTSSuperpod"]/size</xpath>
          <value>
            <size>(3,3)</size>
          </value>
        </li>
        <li Class="PatchOperationReplace">
          <xpath>/Defs/ThingDef[defName="SRTSSkip"]/size</xpath>
          <value>
            <size>(3,3)</size>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
  
  <Operation Class="PatchOperationSequence">
  <operations>
    <li Class="PatchOperationAdd" MayRequire="Ludeon.Rimworld.odyssey"> 
      <xpath>Defs/ThingDef[defName="PilotConsole"]/comps</xpath>
      <value>
        <li Class="CompProperties_AirDockForGravship">
		 <stackLimit>1</stackLimit>
		 </li>
      </value>
    </li>
  </operations>
</Operation>
</Patch>