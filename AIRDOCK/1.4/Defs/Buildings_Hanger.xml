<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <DesignatorDropdownGroupDef>
    <defName>Hanger_SET</defName>
  </DesignatorDropdownGroupDef>

<ThingDef ParentName="BuildingBase">
    <defName>Air_cargo</defName>
    <label>Air Hanger(small)</label>
	<description>A hangar is a building where aircraft are stored and inspected and maintained.</description>
    <thingClass>AirDock.Building_HangerBuilding</thingClass>
	<graphicData>
      <texPath>Things/Air_cargo/Aircargo</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(7.2,7.2)</drawSize>
    </graphicData>
	<castEdgeShadows>True</castEdgeShadows>
    <altitudeLayer>Building</altitudeLayer>
	<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <rotatable>true</rotatable>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>0.5</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <WorkToBuild>8000</WorkToBuild>
      <MaxHitPoints>2000</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <size>(5,5)</size>
    <designationCategory>Ship</designationCategory>
    <hasInteractionCell>false</hasInteractionCell>
    <interactionCellOffset>(1,0,0)</interactionCellOffset>
    <placeWorkers>
      <li>PlaceWorker_WatchAreahangar</li>
    </placeWorkers>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <shortCircuitInRain>true</shortCircuitInRain>
        <basePowerConsumption>200</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
    </comps>
    <defaultPlacingRot>South</defaultPlacingRot>
    <building>
      <watchBuildingStandDistanceRange>3~7</watchBuildingStandDistanceRange>
      <watchBuildingStandRectWidth>5</watchBuildingStandRectWidth>
    </building>
    <costStuffCount>40</costStuffCount>
	<stuffCategories>
      <li>Metallic</li>
    </stuffCategories>
    <costList>
      <Steel>1000</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
	<uiIconScale>0.9</uiIconScale>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
  </ThingDef>
  
  <ThingDef ParentName="BuildingBase">
    <defName>Air_cargo_two</defName>
    <label>Air Hanger(big)</label>
	<description>A hangar is a building where aircraft are stored and inspected and maintained.</description>
    <thingClass>AirDock.Building_HangerBuilding</thingClass>
	<graphicData>
      <texPath>Things/Air_cargo/AirHanger</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
	  <shadowData>
          <volume>(5, 0, 5)</volume>
          <offset>(0,0,-1)</offset>
        </shadowData>
      <drawSize>(9,9)</drawSize>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
	<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <rotatable>true</rotatable>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>0.5</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <WorkToBuild>8000</WorkToBuild>
      <MaxHitPoints>2000</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <size>(9,9)</size>
    <designationCategory>Ship</designationCategory>
    <hasInteractionCell>false</hasInteractionCell>
    <interactionCellOffset>(1,0,0)</interactionCellOffset>
    <placeWorkers>
      <li>PlaceWorker_WatchAreahangar</li>
    </placeWorkers>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <shortCircuitInRain>true</shortCircuitInRain>
        <basePowerConsumption>200</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
    </comps>
    <defaultPlacingRot>South</defaultPlacingRot>
    <building>
      <watchBuildingStandDistanceRange>5~13</watchBuildingStandDistanceRange>
      <watchBuildingStandRectWidth>9</watchBuildingStandRectWidth>
    </building>
    <costStuffCount>40</costStuffCount>
	<stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <costList>
      <Steel>1000</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
	<uiIconScale>0.9</uiIconScale>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
  </ThingDef>
  
